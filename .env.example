# Automatic provider recognition. Supported values: gemini, openai-compatible
# If omitted, the server defaults to Gemini when only GOOGLE_API_KEY is set, 
# or OpenAI-compatible when only the complete OpenAI-compatible config below is set. 

# If both are configured, set RECOGNITION_PROVIDER explicitly.
# RECOGNITION_PROVIDER=gemini


# Gemini mode
GOOGLE_API_KEY=your_google_gemini_api_key_here
# All Gemini fallback attempts use the same GOOGLE_API_KEY and project quota pool.
# Default model chain (when neither override is set):
#   gemini-3.5-flash -> gemini-3-flash-preview -> gemini-2.5-flash -> gemini-3.1-flash-lite
# Single-model override — disables fallback. Do not set with GEMINI_MODELS.
# GEMINI_MODEL=gemini-3.5-flash
# Comma-separated ordered fallback list. Duplicates removed (first kept). Do not set with GEMINI_MODEL.
# GEMINI_MODELS=gemini-3.5-flash,gemini-2.5-flash


# Generic OpenAI-compatible mode
# RECOGNITION_PROVIDER=openai-compatible
# OPENAI_COMPATIBLE_API_KEY=your_openai_compatible_api_key_here
# OPENAI_COMPATIBLE_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_COMPATIBLE_MODEL=xiaomi/mimo-v2.5
# OPENAI_COMPATIBLE_PROVIDER_LABEL=OpenRouter


# OpenAI-compatible audio is supported for .wav and .mp3 files only.
# Audio files are sent as input_audio content parts with raw base64 data
# and format metadata. The selected model must support input_audio.


# Direct Xiaomi MiMo OpenAI-compatible endpoint example
# OPENAI_COMPATIBLE_BASE_URL=https://api.xiaomimimo.com/v1
# OPENAI_COMPATIBLE_MODEL=mimo-v2.5
# OPENAI_COMPATIBLE_PROVIDER_LABEL=Xiaomi MiMo OpenAI-compatible API


# Maximum local media size, in bytes, for OpenAI-compatible base64 request bodies.
# Defaults to 20971520 (20 MiB).
# MAX_INLINE_MEDIA_BYTES=20971520

# Transport type: 'stdio' or 'sse' (defaults to 'stdio')
TRANSPORT_TYPE=stdio

# Port for SSE transport (defaults to 3000)
PORT=3000

# Log level: 'verbose', 'debug', 'info', 'warn', 'error', 'fatal' (defaults to 'fatal')
LOG_LEVEL=fatal
